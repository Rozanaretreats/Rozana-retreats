# Supabase (same project as Rozana web app)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=sb_publishable_your_key_here

# Kiosk device binding — one tablet per property
PROPERTY_ID=ooty-skyview
DEVICE_ID=kiosk-ooty-01

# Admin PIN for enrolment screen (change before production)
ADMIN_PIN=1234

# Fingerprint reader: mock | native
# Defaults to mock in debug builds when unset.
FINGERPRINT_READER=mock

# Mock reader: staff id returned on simulated scan (must exist in staff table)
MOCK_STAFF_ID=

# Optional secondary WebView tab (Rozana Ops dashboard on same tablet)
ENABLE_WEBVIEW_TAB=false
WEB_APP_URL=http://localhost:5173

# Debounce duplicate punches within this many seconds
PUNCH_DEBOUNCE_SECONDS=30

# Minimum match score (0–100) to accept identification
MIN_MATCH_SCORE=60
