# Supabase — Project Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Optional — pre-biometric testing only. Remove or set false when devices are live.
VITE_ALLOW_MANUAL_PUNCHES=true

# Security: run supabase/migrations/011_security_hardening.sql (or re-run setup.sql) in Supabase SQL Editor.
# This hashes staff passwords, blocks direct staff_logins reads, and makes HK photos private.

# For migrations only (not used by the Vite app). Save this file after editing.
SUPABASE_DB_PASSWORD=your-database-password

# Optional — paste full URI from Supabase → Database → Connection string (overrides password above)
# SUPABASE_DB_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
