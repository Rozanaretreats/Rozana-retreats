# Supabase (same project as Rozana Ops)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=sb_publishable_your_key_here
# Secret key (sb_secret_...) — enables report_send_log idempotency (never commit the real value)
SUPABASE_SERVICE_ROLE_KEY=

# Edge Function that builds the report text (dry run — Baileys sends it)
EOD_FUNCTION_URL=https://YOUR_PROJECT_REF.supabase.co/functions/v1/send-owner-eod-report

# Property to report (go-live: ooty-skyview)
PROPERTY_ID=ooty-skyview

# Owner numbers — digits only, comma-separated
OWNER_WHATSAPP_NUMBERS=919876543210,919876543211

# Daily send time — cron in Asia/Kolkata (default 6:00 PM IST)
EOD_CRON=0 18 * * *

# Folder for WhatsApp Web session (created after QR scan)
BAILEYS_AUTH_DIR=auth_info

# Optional — Slack/Discord webhook for send failures and WhatsApp logout
# FAILURE_WEBHOOK_URL=https://hooks.slack.com/services/...
# MAX_SENDS_PER_DAY=3 — required for GET /send-now on 127.0.0.1 (set in send-now.cmd)
TRIGGER_SECRET=
